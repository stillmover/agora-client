{
  "name": "reddit-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "bun": "^1.2.13"
  },
  "scripts": {
    "dev": "vite --open",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint src/",
    "lint:aware": "oxlint --type-aware",
    "lint:fix": "oxlint --fix src/ && bun run fmt",
    "preview": "vite preview",
    "prepare": "lefthook install && bun scripts/setup-dev.ts",
    "preinstall": "npx only-allow bun",
    "type-check": "tsc --noEmit",
    "codegen:gql": "node scripts/generate-all-operations.js && graphql-codegen --config codegen.graphql.yml",
    "codegen:rest": "orval --config orval.config.ts",
    "codegen": "bun run codegen:gql && bun run codegen:rest"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@sentry/react": "^10.29.0",
    "@sentry/types": "^10.29.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-devtools": "^0.8.4",
    "@tanstack/react-form": "^1.27.2",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-router": "^1.140.5",
    "@tanstack/react-router-devtools": "^1.140.5",
    "@tanstack/react-store": "^0.8.0",
    "@tanstack/store": "^0.8.0",
    "@urql/devtools": "^2.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.559.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-error-boundary": "^6.0.0",
    "react-scan": "^0.4.3",
    "react-use": "^17.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "urql": "^5.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.1",
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/typescript": "^5.0.6",
    "@graphql-codegen/typescript-operations": "^5.0.6",
    "@graphql-codegen/typescript-urql": "^4.0.1",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@tanstack/router-plugin": "^1.140.5",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.2.3",
    "globals": "^16.5.0",
    "graphql": "^16.12.0",
    "lefthook": "^2.0.9",
    "node-fetch": "^3.3.2",
    "npm-run-all2": "^8.0.4",
    "orval": "^7.17.0",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.32.0",
    "oxlint-tsgolint": "^0.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.2.7",
    "vite-bundle-analyzer": "^1.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
