{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "singleQuote": false,
  "trailingComma": "es5",
  "semi": true,
  "arrowParens": "always",
  "ignorePatterns": [
    "node_modules",
    "dist",
    "dev-dist",
    "build",
    "coverage",
    ".next",
    "storybook-static",
    "src/shared/api/**/*",
    "scripts/**/*",
    "tsconfig*.json",
    "tsconfig.app.json",
    "public/**/*",
    "**/*.config.{js,ts,mjs,cjs,json,yml,yaml}",
  ],
}
