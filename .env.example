# Application Configuration
VITE_APP_NAME="Reddit Client"
VITE_APP_VERSION="1.0.0"
VITE_APP_ENV="development"

# Server Configuration
VITE_HOST="localhost"
VITE_PORT="5173"
VITE_PREVIEW_PORT="4173"

# Backend API Configuration
VITE_BACKEND_URL="http://localhost:8000"
VITE_API_BASE_URL="https://www.reddit.com/api/v1"
VITE_API_TIMEOUT="10000"

# Reddit API Configuration
VITE_REDDIT_CLIENT_ID="your_reddit_client_id_here"
VITE_REDDIT_CLIENT_SECRET="your_reddit_client_secret_here"
VITE_REDDIT_USER_AGENT="RedditClient/1.0.0"

# OAuth Configuration
VITE_REDDIT_REDIRECT_URI="http://localhost:5173/auth/callback"

# Feature Flags
VITE_ENABLE_ANALYTICS="false"
VITE_ENABLE_ERROR_REPORTING="true"
VITE_ENABLE_DEBUG_MODE="true"

# External Services
VITE_SENTRY_DSN=""
VITE_GA_TRACKING_ID=""
VITE_HOTJAR_ID=""
