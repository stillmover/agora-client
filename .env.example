# Backend API Configuration
# Required: The URL of your backend API server
VITE_BACKEND_URL=http://localhost:8000

# Google OAuth Configuration
# Optional: Only required if you're using Google authentication
# Get these from Google Cloud Console: https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Error Tracking
# Optional: Sentry DSN for error monitoring in production
# Get this from Sentry: https://sentry.io/
VITE_SENTRY_DSN=

# Development Server Configuration
# Optional: Customize dev server settings (these have sensible defaults)
# VITE_HOST=localhost
# VITE_PORT=5173
# VITE_PREVIEW_PORT=4173

# Application Environment
# Optional: Set the environment (defaults to "development")
# VITE_APP_ENV=development
